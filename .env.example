NODE_ENV=development
PORT=3000
PLAKY_BASE_URL=https://api.plaky.com/v1/public
# Optional: set to skip passing space_id/board_id on every call (single-board setups)
# Omit or leave blank when working with multiple boards — use plaky_list_boards to discover IDs
PLAKY_DEFAULT_SPACE_ID=
PLAKY_DEFAULT_BOARD_ID=
REDIS_URL=
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
